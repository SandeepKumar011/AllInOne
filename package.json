{
  "name": "playtypeconfidence",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js test || true",
    "posttest": "ts-node helper/generate-report.ts",
    "particularfeature": "npx cucumber-js features/login.feature",
    "onlySmoke": "npx cucumber-js features/login.feature --tags '@Smoke'",
    "onlyRegression": "npx cucumber-js features/login.feature --tags '@Regression'",
    "smoke": "npx cucumber-js --tags @Smoke --parallel 2",
    "both": "npx cucumber-js --tags '@Regression and @Smoke' --parallel 2",
    "fireFoxBrowser": "set BROWSER=firefox && npx cucumber-js features/login.feature"
  },
